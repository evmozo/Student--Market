PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/student_marketplace
USE_MEMORY_MONGO=false
SEED_DEMO_DATA=false

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
PASSWORD_RESET_MINUTES=30

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=NEMSU Market <no-reply@nemsumarket.local>

FRIENDS_ONLY_MESSAGING=false

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_BUCKET=student-marketplace
